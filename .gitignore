# Generated site output
/_site/

# Jekyll caches
/.jekyll-cache/
/.jekyll-metadata
/.sass-cache/

# Asset bundler cache (used by some themes)
/_asset_bundler_cache/

# Gemfile.lock is intentionally tracked.
# It ensures consistent builds across local development, GitHub Actions, and Cloudflare Pages deployments.

# Bundler dependencies
/.bundle/

# Vendor directory (only used if vendorizing gems)
/vendor/

# Ruby gems
/*.gem

# Because Mac, latter due to hidden macOS metadata files created on non-Mac file systems
.DS_Store
._*

# Because Windows
Thumbs.db
Desktop.ini

# VS Code: keep shared workspace settings and extension recommendations, Ignore personal/editor-specific files.
# Add additional shared VS Code settings here as needed.
/.vscode/*
!/.vscode/settings.json
!/.vscode/extensions.json

# Node.js tooling (uncomment if using npm packages locally)
# /node_modules/
# /npm-debug.log*

# Temporary files
*.tmp
*.temp

# Logs
*.log
