# Normalize text files to LF in the repository.
* text=auto eol=lf

# Shell Scripts
*.ps1 text eol=lf
*.sh text eol=lf

# GitHub/Cloudflare workflows
*.yml text eol=lf
*.toml text eol=lf
CNAME text eol=lf

# Dot files
.editorconfig text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf
.ruby-version text eol=lf

# Ruby / Jekyll
Gemfile text eol=lf
*.lock text eol=lf
*.css text eol=lf
*.html text eol=lf
*.js text eol=lf
*.json text eol=lf
*.markdown text eol=lf
*.md text eol=lf
*.rb text eol=lf
*.scss text eol=lf
*.txt text eol=lf
*.xml text eol=lf
*.yaml text eol=lf

# Images
*.gif binary
*.ico binary
*.jpeg binary
*.jpg binary
*.png binary
*.svg text eol=lf
*.webp binary

# Fonts
*.otf binary
*.ttf binary
*.woff binary
*.woff2 binary

# Misc
*.csv text eol=lf
*.liquid text eol=lf
*.mp3 binary
*.pdf binary
*.webmanifest text eol=lf
*.zip binary

# GitHub language statistics
_sass/minimal-mistakes/vendor/* linguist-vendored
assets/fonts/*                  linguist-vendored
assets/js/lunr/*                linguist-vendored
assets/js/main.min.js           linguist-vendored
assets/js/plugins/*             linguist-vendored
assets/js/vendor/*              linguist-vendored
